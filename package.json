{
    "name": "graphql-class-validator-to-arktype",
    "version": "0.0.1",
    "private": true,
    "type": "commonjs",
    "scripts": {
        "start:cv": "ts-node -T src/classvalidator/main.ts",
        "start:ak": "ts-node -T src/arktype/main.ts",
        "start:zod": "ts-node -T src/zod/main.ts",
        "start:demo": "ts-node -T src/arktype-demo/main.ts",
        "start:demo:cv": "ts-node -T src/classvalidator-demo/main.ts",
        "start:demo:zod": "ts-node -T src/zod-demo/main.ts",
        "bench": "ts-node -T src/bench/run.ts",
        "bench:micro": "ts-node -T src/bench/micro.ts",
        "bench:demo": "ts-node -T src/bench/run-demo.ts",
        "test": "vitest run src/util-validators src/arktype/graphql-arktype",
        "test:watch": "vitest src/util-validators src/arktype/graphql-arktype",
        "typecheck": "tsgo --noEmit -p tsconfig.typecheck.json",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "format": "prettier --write ."
    },
    "dependencies": {
        "@apollo/server": "^4.11.2",
        "@as-integrations/express5": "^1.1.2",
        "@nestjs/apollo": "^13.0.3",
        "@nestjs/common": "^11.0.1",
        "@nestjs/core": "^11.0.1",
        "@nestjs/graphql": "^13.0.3",
        "@nestjs/platform-express": "^11.0.1",
        "arktype": "^2.1.20",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.3",
        "es-toolkit": "^1.46.1",
        "graphql": "^16.10.0",
        "graphql-tag": "^2.12.6",
        "libphonenumber-js": "^1.12.42",
        "nestjs-zod": "^5.3.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "ts-essentials": "^10.2.0",
        "zod": "^4.4.2"
    },
    "devDependencies": {
        "@nestjs/testing": "^11.1.19",
        "@types/autocannon": "^7.12.7",
        "@types/express": "^5.0.6",
        "@types/node": "^22.10.5",
        "@types/supertest": "^7.2.0",
        "@typescript/native-preview": "7.0.0-dev.20260503.1",
        "autocannon": "^8.0.0",
        "oxlint": "^1.62.0",
        "prettier": "^3.8.3",
        "prettier-plugin-jsdoc": "^1.8.0",
        "prettier-plugin-organize-attributes": "^1.0.0",
        "prettier-plugin-organize-imports": "^4.3.0",
        "supertest": "^7.2.2",
        "ts-node": "^10.9.2",
        "tslib": "^2.8.1",
        "tsx": "^4.21.0",
        "typescript": "^5.7.3",
        "vitest": "^4.1.5"
    }
}
