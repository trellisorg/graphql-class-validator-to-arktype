{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "moduleResolution": "bundler",
        "module": "preserve",
        "noEmit": true,
        "strict": true,
        "noImplicitAny": true,
        "strictPropertyInitialization": true,
        "skipLibCheck": true,
        "lib": ["ES2023"]
    },
    "include": ["src/**/*"],
    "exclude": ["src/util-decorators/**/*", "node_modules", "dist"]
}
